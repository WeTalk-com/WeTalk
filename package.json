{
  "name": "WeTalk",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest run"
  },
  "devDependencies": {
    "prettier": "^3.8.5",
    "turbo": "^2.10.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
