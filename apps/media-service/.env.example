# Copier en .env

# Port HTTP
PORT=4004

# Secret JWT partagé avec les autres services (vérification locale du token d'accès)
JWT_ACCESS_SECRET=local-access-secret-change-me

# CORS — laisser vide en dev
CORS_ORIGIN=

# Stockage des fichiers (monté sur un volume Docker en prod)
UPLOAD_DIR=/data/uploads

# Tailles maximales (octets)
# 5 Mo
MAX_IMAGE_BYTES=5242880
# 50 Mo
MAX_VIDEO_BYTES=52428800
