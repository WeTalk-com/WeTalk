# Copier le .env.example en .env

# JWT
JWT_ACCESS_SECRET=local-access-secret-change-me
JWT_REFRESH_SECRET=local-refresh-secret-change-me

# CORS
# Laissez vide en dev
CORS_ORIGIN=

# PostgreSQL
POSTGRES_USER=wetalk
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wetalk_db

# Auth service DB + Redis
DB_HOST=postgres
DB_PORT=5432
DB_NAME=wetalk_db
DB_USER=wetalk
DB_PASSWORD=changeme
REDIS_URL=redis://redis:6379

# Révocation d'access token (denylist Redis du ban). Doit être >= JWT_ACCESS_EXPIRES_IN.
ACCESS_REVOKE_TTL_SECONDS=900

# MongoDB (post-service)
MONGO_URI_POST=mongodb://mongo:27017/wetalk_posts

# Post-service -> user-service (vérification ban/suspension à la publication)
USER_SERVICE_URL=http://user-service:4001

# Next.js (web)
NEXT_PUBLIC_API_URL=/api
# Base interne pour le SSR (web -> gateway en absolu, cookie relaye via next/headers)
API_INTERNAL_URL=http://gateway/api